{
  "format_version": "1.20.0",
  "minecraft:entity": {
    "description": {
      "identifier": "custom:gugugaga_penguin",
      "is_spawnable": true,
      "is_summonable": true,
      "is_experimental": false,
      "properties": {
        "gugugaga:has_weapon": {
          "type": "bool",
          "default": false,
          "client_sync": true
        }
      }
    },
    "component_groups": {
      "gugugaga:awake_mode": {
        "minecraft:behavior.open_door": { "priority": 1, "close_door_after": true },
        "minecraft:behavior.look_at_player": { "priority": 5, "look_distance": 6.0, "probability": 0.02 },
        "minecraft:behavior.random_look_around": { "priority": 6 },
        "minecraft:collision_box": { "width": 0.5, "height": 1.0 },
        "minecraft:pushable": { "is_pushable": true, "is_pushable_by_piston": true }
      },
      "gugugaga:sleeping_mode": {
        "minecraft:variant": { "value": 1 },
        "minecraft:collision_box": { "width": 0.0, "height": 0.0 },
        "minecraft:pushable": { "is_pushable": false, "is_pushable_by_piston": false }
      },
      "gugugaga:weapon_light":  { "minecraft:attack": { "damage": 7  } },
      "gugugaga:weapon_medium": { "minecraft:attack": { "damage": 10 } },
      "gugugaga:weapon_heavy":  { "minecraft:attack": { "damage": 14 } },
      "gugugaga:guard_mode": {
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 1,
          "within_radius": 16.0,
          "must_see": true,
          "entity_types": [
            { "filters": { "test": "is_family", "subject": "other", "value": "monster" }, "max_dist": 16 }
          ]
        },
        "minecraft:behavior.melee_attack": {
          "priority": 2,
          "speed_multiplier": 1.4,
          "track_target": true
        }
      },
      "gugugaga:guard_mode_off": {
        "minecraft:behavior.nearest_attackable_target": {
          "priority": 99,
          "within_radius": 0
        }
      },
      "gugugaga:hp_tier1": { "minecraft:health": { "value": 40, "max": 40 } },
      "gugugaga:hp_tier2": { "minecraft:health": { "value": 60, "max": 60 } },
      "gugugaga:hp_tier3": { "minecraft:health": { "value": 80, "max": 80 } },
      "gugugaga:follow_mode": {
        "minecraft:variant": { "value": 0 },
        "minecraft:behavior.follow_owner": { "priority": 2, "speed_multiplier": 1.5, "start_distance": 4.0, "stop_distance": 2.0 },
        "minecraft:behavior.random_stroll": { "priority": 3, "speed_multiplier": 1.0 }
      },
      "gugugaga:sit_mode": {
        "minecraft:variant": { "value": 2 }
      },
      "gugugaga:finding_bed_mode": {
        "minecraft:variant": { "value": 0 },
        "minecraft:behavior.move_to_block": {
          "priority": 2,
          "tick_interval": 5,
          "search_range": 16,
          "search_height": 3,
          "goal_radius": 2.5,
          "movement_speed": 1.5,
          "target_blocks": [
            "minecraft:white_bed", "minecraft:orange_bed", "minecraft:magenta_bed", "minecraft:light_blue_bed",
            "minecraft:yellow_bed", "minecraft:lime_bed", "minecraft:pink_bed", "minecraft:gray_bed",
            "minecraft:light_gray_bed", "minecraft:cyan_bed", "minecraft:purple_bed", "minecraft:blue_bed",
            "minecraft:brown_bed", "minecraft:green_bed", "minecraft:red_bed", "minecraft:black_bed", "minecraft:bed"
          ]
        },
        "minecraft:behavior.random_stroll": { "priority": 4, "speed_multiplier": 1.0 }
      }
    },
    "components": {
      "minecraft:type_family": { "family": [ "penguin", "mob" ] },
      "minecraft:variant": { "value": 0 },
      "minecraft:health": { "value": 20, "max": 20 },
      "minecraft:attack": { "damage": 5 },
      "minecraft:movement": { "value": 0.25 },
      "minecraft:inventory": { "inventory_size": 27, "private": true },
      "minecraft:navigation.walk": {
        "is_amphibious": true,
        "can_path_over_water": true,
        "can_pass_doors": true,
        "can_open_doors": true
      },
      "minecraft:movement.basic": {},
      "minecraft:jump.static": {},
      "minecraft:physics": {},
      "minecraft:tameable": { "probability": 1.0, "tame_items": [ "minecraft:cookie" ] },
      "minecraft:equippable": {
        "slots": [
          {
            "slot": 0,
            "item": "minecraft:air",
            "accepted_items": [
              "minecraft:wooden_sword", "minecraft:stone_sword", "minecraft:iron_sword",
              "minecraft:golden_sword", "minecraft:diamond_sword", "minecraft:netherite_sword",
              "minecraft:wooden_axe", "minecraft:stone_axe", "minecraft:iron_axe",
              "minecraft:golden_axe", "minecraft:diamond_axe", "minecraft:netherite_axe",
              "minecraft:wooden_pickaxe", "minecraft:stone_pickaxe", "minecraft:iron_pickaxe",
              "minecraft:golden_pickaxe", "minecraft:diamond_pickaxe", "minecraft:netherite_pickaxe"
            ]
          }
        ]
      },
      "minecraft:interact": {
        "interactions": [
          {
            "on_interact": { "filters": { "test": "is_owner", "subject": "other", "value": true } },
            "interact_text": "action.interact.gugugaga",
            "use_item": false,
            "swing": true
          }
        ]
      }
    },
    "events": {
      "minecraft:entity_spawned": { "add": { "component_groups": [ "gugugaga:follow_mode", "gugugaga:awake_mode" ] } },
      "gugugaga:sit": {
        "remove": { "component_groups": [ "gugugaga:follow_mode", "gugugaga:finding_bed_mode", "gugugaga:sleeping_mode" ] },
        "add":    { "component_groups": [ "gugugaga:sit_mode", "gugugaga:awake_mode" ] }
      },
      "gugugaga:follow": {
        "remove": { "component_groups": [ "gugugaga:sit_mode", "gugugaga:finding_bed_mode", "gugugaga:sleeping_mode" ] },
        "add":    { "component_groups": [ "gugugaga:follow_mode", "gugugaga:awake_mode" ] }
      },
      "gugugaga:move_to_bed": {
        "remove": { "component_groups": [ "gugugaga:sit_mode", "gugugaga:follow_mode", "gugugaga:sleeping_mode" ] },
        "add":    { "component_groups": [ "gugugaga:finding_bed_mode", "gugugaga:awake_mode" ] }
      },
      "gugugaga:sleep_now": {
        "remove": { "component_groups": [ "gugugaga:sit_mode", "gugugaga:follow_mode", "gugugaga:finding_bed_mode", "gugugaga:awake_mode" ] },
        "add":    { "component_groups": [ "gugugaga:sleeping_mode" ] }
      },
      "gugugaga:enable_guard": {
        "remove": { "component_groups": [ "gugugaga:guard_mode_off" ] },
        "add":    { "component_groups": [ "gugugaga:guard_mode" ] }
      },
      "gugugaga:disable_guard": {
        "remove": { "component_groups": [ "gugugaga:guard_mode" ] },
        "add":    { "component_groups": [ "gugugaga:guard_mode_off" ] }
      },
      "gugugaga:equip_light": {
        "remove": { "component_groups": [ "gugugaga:weapon_medium", "gugugaga:weapon_heavy" ] },
        "add":    { "component_groups": [ "gugugaga:weapon_light" ] }
      },
      "gugugaga:equip_medium": {
        "remove": { "component_groups": [ "gugugaga:weapon_light", "gugugaga:weapon_heavy" ] },
        "add":    { "component_groups": [ "gugugaga:weapon_medium" ] }
      },
      "gugugaga:equip_heavy": {
        "remove": { "component_groups": [ "gugugaga:weapon_light", "gugugaga:weapon_medium" ] },
        "add":    { "component_groups": [ "gugugaga:weapon_heavy" ] }
      },
      "gugugaga:unequip_weapon_damage": {
        "remove": { "component_groups": [ "gugugaga:weapon_light", "gugugaga:weapon_medium", "gugugaga:weapon_heavy" ] }
      },
      "gugugaga:upgrade_hp_1": {
        "remove": { "component_groups": [ "gugugaga:hp_tier2", "gugugaga:hp_tier3" ] },
        "add":    { "component_groups": [ "gugugaga:hp_tier1" ] }
      },
      "gugugaga:upgrade_hp_2": {
        "remove": { "component_groups": [ "gugugaga:hp_tier1", "gugugaga:hp_tier3" ] },
        "add":    { "component_groups": [ "gugugaga:hp_tier2" ] }
      },
      "gugugaga:upgrade_hp_3": {
        "remove": { "component_groups": [ "gugugaga:hp_tier1", "gugugaga:hp_tier2" ] },
        "add":    { "component_groups": [ "gugugaga:hp_tier3" ] }
      }
    }
  }
}
