{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "custom:gugugaga_penguin",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/gugugaga_penguin.png"
      },
      "geometry": {
        "default": "geometry.gugugaga"
      },
      "spawn_egg": {
        "base_color": "#2D2D2D",
        "overlay_color": "#FFFFFF"
      },
      "animations": {
        "idle":       "animation.gugugaga.idle",
        "walk":       "animation.gugugaga.walk",
        "run":        "animation.gugugaga.run",
        "jump":       "animation.gugugaga.jump",
        "sit":        "animation.gugugaga.sit",
        "sleep":      "animation.gugugaga.sleep",
        "swim":       "animation.gugugaga.swim_stand",
        "boat":       "animation.gugugaga.boat",
        "attacked":   "animation.gugugaga.attacked",
        "death":      "animation.gugugaga.death",
        "swing_hand": "animation.gugugaga.swing_hand",
        "attack":     "animation.gugugaga.use_mainhand",
        "offhand":    "animation.gugugaga.use_offhand",
        "chair":      "animation.gugugaga.chair",
        "beg":        "animation.gugugaga.beg",
        "idle_sound": "animation.gugugaga.idle_sound"
      },
      "scripts": {
        "animate": [
          { "sleep":      "query.variant == 1" },
          { "sit":        "query.variant == 2" },
          { "boat":       "query.is_riding && query.variant == 0" },
          { "swim":       "query.is_in_water && query.variant == 0" },
          { "attacked":   "query.hurt_time > 0 && query.variant == 0" },
          { "swing_hand": "query.property('gugugaga:has_weapon') == true && query.variant == 0 && !query.is_in_water && !query.is_riding" },
          { "run":        "query.modified_move_speed > 0.3 && query.variant == 0 && !query.is_in_water && !query.is_riding" },
          { "walk":       "query.modified_move_speed > 0.05 && query.modified_move_speed <= 0.3 && query.variant == 0 && !query.is_in_water && !query.is_riding" },
          { "idle":       "query.variant == 0 && !query.is_in_water && !query.is_riding" },
          "idle_sound"
        ]
      },
      "render_controllers": [
        "controller.render.gugugaga"
      ]
    }
  }
}
