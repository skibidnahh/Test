{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "custom:gugugaga_penguin",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/gugugaga_penguin.png"
      },
      "geometry": {
        "default": "geometry.gugugaga"
      },
      "spawn_egg": {
        "base_color": "#2D2D2D",
        "overlay_color": "#FFFFFF"
      },
      "animations": {
        "idle": "animation.gugugaga.idle",
        "walk": "animation.gugugaga.walk",
        "sleep": "animation.gugugaga.sleep",
        "idle_sound": "animation.gugugaga.idle_sound"
      },
      "scripts": {
        "pre_animation": [
          "variable.tame_anim = query.is_tamed;"
        ],
        "animate": [
          {
            "idle": "query.variant != 1"
          },
          "idle_sound",
          {
            "walk": "query.modified_move_speed > 0.05 && query.variant != 1"
          },
          {
            "sleep": "query.variant == 1"
          }
        ]
      },
      "render_controllers": [
        "controller.render.default"
      ]
    }
  }
}

